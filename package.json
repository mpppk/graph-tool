{
  "name": "graph-tool",
  "version": "0.1.0",
  "description": "Graph/network management CLI + Web UI — single Bun binary",
  "type": "module",
  "bin": {
    "graph-tool": "./dist/graph-tool"
  },
  "scripts": {
    "dev": "bun --hot src/index.ts",
    "build": "bun run build.ts",
    "build:binary": "bun run build-binary.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint src/",
    "format": "biome format --write src/",
    "check": "biome check src/"
  },
  "dependencies": {
    "@orpc/client": "^1.0.0",
    "@orpc/server": "^1.0.0",
    "@tanstack/react-query": "^5.0.0",
    "@xyflow/react": "^12.10.2",
    "drizzle-orm": "^0.45.0",
    "elkjs": "^0.11.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "bun-plugin-tailwind": "^0.1.0",
    "bun-types": "latest",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
